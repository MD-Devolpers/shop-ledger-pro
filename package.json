{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@11.10.0",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.10.0",
      "onFail": "ignore"
    }
  },
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock'",
    "start": "sh start-railway.sh",
    "build": "pnpm -r --if-present run build && pnpm --filter @workspace/db push --force",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@swc/core", "esbuild", "msw", "unrs-resolver"]
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
